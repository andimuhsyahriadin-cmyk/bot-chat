# Telegram Userbot Configuration - INDONESIA FOKUS 🇮🇩

# Telegram Credentials
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your_api_hash_here
GEMINI_API_KEY=your_gemini_key_here

# Bot Target - INDONESIA GROUP ONLY
TARGET_GROUP=interlinkIDchat
INDONESIA_TOPIC_ID=26251

# Bot Behavior - 3-CHAT CYCLE (JANGAN UBAH KECUALI TAHU MAKSUDNYA)
# Delay antar reply dalam cycle (15-30 detik)
REPLY_DELAY_MIN=15
REPLY_DELAY_MAX=30

# Rest period setelah cycle (1:50 - 2:10 = 110-130 detik)
REST_DURATION_MIN=110
REST_DURATION_MAX=130

# Smart open jika sepi (60 detik)
SILENCE_THRESHOLD=60
